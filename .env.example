# Copy this file to .env for local development.
# On Railway, set these as Environment Variables in the project settings instead.

# Your Anthropic API key (server-side only, never exposed to the browser)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Shared password the whole team uses to log into Hemingway
TEAM_PASSWORD=change-this-password

# Random long string used to sign session cookies. Generate one with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-this-to-a-random-string

# Port the server runs on locally (Railway sets this automatically in production)
PORT=3000
